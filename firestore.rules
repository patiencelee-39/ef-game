rules_version = '2';

// ====================================
// Firestore 安全規則
// ====================================
// 對應：排行榜系統（二軌制）
//
// 用途：
//   1. 📋 班級排行榜（classLeaderboards）— 持久化，老師不刪就一直在
//   2. 🌐 世界排行榜（worldLeaderboard）— 匿名上傳，覆蓋或過期刪除
// ====================================
//
// ┌─────────────────────────────────────────────────────────────┐
// │ 🔑 管理員 UID 設定                                          │
// │                                                             │
// │ 下方的 ADMIN_UID 是「允許刪除任何人資料」的管理員帳號。      │
// │                                                             │
// │ ★ 什麼時候需要改？                                          │
// │   - 你清除了瀏覽器資料（Cookie/localStorage）               │
// │   - 你換了電腦或瀏覽器                                      │
// │   - 你看到 admin 工具「刪除」按鈕出現「權限不足」錯誤       │
// │                                                             │
// │ ★ 怎麼改？                                                  │
// │   1. 打開 admin 工具頁面（tools/admin.html）                │
// │   2. 頁面上方「🔑 管理員身份」區域會顯示你的完整 UID        │
// │   3. 點「📋 複製」按鈕複製 UID                              │
// │   4. 回到這個檔案，找到下方寫著 ADMIN_UID 的那一行          │
// │   5. 把引號裡面的內容換成你剛複製的 UID                     │
// │   6. 在終端機執行：firebase deploy                          │
// │   7. 重新整理 admin 頁面，完成！                            │
// │                                                             │
// │ ★ Fork 的教師：                                             │
// │   你第一次部署時就要改這個值，換成你自己的 UID。            │
// │   查看方式同上（打開你自己部署的 tools/admin.html）。        │
// └─────────────────────────────────────────────────────────────┘

service cloud.firestore {
  match /databases/{database}/documents {

    // ─────────────────────────────────
    // 📋 班級排行榜（持久化，老師管理）
    // 路徑：/classLeaderboards/{boardId}/entries/{entryId}
    // boardId = 老師建立時自動產生的 ID
    // ─────────────────────────────────
    match /classLeaderboards/{boardId} {
      // ✅ 看板元資料：任何已驗證用戶可讀取
      allow read: if request.auth != null;

      // ✅ 建立看板：已驗證用戶可建立（記錄 ownerId）
      allow create: if request.auth != null
        && request.resource.data.keys().hasAll(['ownerId', 'boardName', 'createdAt'])
        && request.resource.data.ownerId == request.auth.uid
        && request.resource.data.boardName is string
        && request.resource.data.boardName.size() >= 1
        && request.resource.data.boardName.size() <= 50;

      // ✅ 更新/刪除：僅看板擁有者
      allow update, delete: if request.auth != null
        && resource.data.ownerId == request.auth.uid;

      match /entries/{entryId} {
        // ✅ 任何已驗證用戶可讀取（持有代碼/連結即可看）
        allow read: if request.auth != null;

        // ✅ 任何已驗證用戶可寫入（學生匿名上傳）
        allow create, update: if request.auth != null
          && request.resource.data.keys().hasAll(['nickname', 'score', 'accuracy', 'uploadedAt'])
          && request.resource.data.nickname is string
          && request.resource.data.nickname.size() >= 1
          && request.resource.data.nickname.size() <= 20
          && request.resource.data.score is int
          && request.resource.data.score >= 0
          && request.resource.data.score <= 99999
          && request.resource.data.keys().size() <= 15;

        // ✅ 刪除：看板擁有者 或 上傳者本人
        allow delete: if request.auth != null
          && (get(/databases/$(database)/documents/classLeaderboards/$(boardId)).data.ownerId == request.auth.uid
              || resource.data.uid == request.auth.uid);
      }
    }

    // ─────────────────────────────────
    // 🌐 世界排行榜（匿名即可上傳，per-rule 分開存放）
    // 路徑：/worldLeaderboard/{docId}
    // docId = uid_fieldId_ruleId（per-rule）或 uid（舊版相容）
    // 每個 doc 必須帶 uid 欄位 = request.auth.uid
    // ─────────────────────────────────
    match /worldLeaderboard/{docId} {
      // ✅ 任何已驗證用戶可讀取排行榜
      allow read: if request.auth != null;

      // ✅ 已驗證用戶可建立/更新自己的資料（uid 欄位必須等於 auth.uid）
      allow create, update: if request.auth != null
        && request.resource.data.uid == request.auth.uid
        && request.resource.data.nickname is string
        && request.resource.data.nickname.size() >= 1
        && request.resource.data.nickname.size() <= 20
        && (
             (request.resource.data.keys().hasAny(['score']) && request.resource.data.score is int && request.resource.data.score >= 0 && request.resource.data.score <= 99999)
          || (request.resource.data.keys().hasAny(['bestScore']) && request.resource.data.bestScore is int && request.resource.data.bestScore >= 0 && request.resource.data.bestScore <= 99999)
          || (!request.resource.data.keys().hasAny(['score', 'bestScore']))
        )
        && request.resource.data.keys().size() <= 25;

      // ✅ 刪除：本人刪自己的資料，或管理員可刪任何人的
      //         ↓↓↓ ADMIN_UID：換成你的 UID（查看方式見檔案頂部說明）↓↓↓
      allow delete: if request.auth != null
        && (resource.data.uid == request.auth.uid
            || request.auth.uid == "在此貼上你的UID");
      //         ↑↑↑ 把「在此貼上你的UID」換成你的管理員 UID ↑↑↑
    }

    // ─────────────────────────────────
    // � 觀察紀錄表（研究者工具）
    // 路徑：/observationRecords/{docId}
    // 任何已驗證用戶可讀寫
    // ─────────────────────────────────
    match /observationRecords/{docId} {
      allow read, write: if request.auth != null;
    }

    // ─────────────────────────────────
    // �🚫 其他所有集合：預設拒絕
    // ─────────────────────────────────
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
